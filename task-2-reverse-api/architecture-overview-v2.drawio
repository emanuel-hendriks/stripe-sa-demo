        <UserObject label="&lt;pre style=&quot;margin-top: 0px; background-color: rgb(248, 248, 248); border-color: rgb(229, 229, 229); border-style: solid; border-width: 0.833333px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;418&quot; class=&quot;code-line language-http&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;color: rgb(0, 0, 255);&quot;&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; white-space-collapse: collapse; background-color: rgb(236, 236, 236);&quot;&gt;Request 2&lt;/span&gt;&lt;br/&gt;GET&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;/v1/restaurants/rest_abc123/menu&lt;/span&gt; &lt;span class=&quot;hljs-meta&quot; style=&quot;color: rgb(43, 145, 175);&quot;&gt;HTTP/1.1&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Host&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;api.foodco.com&lt;br&gt;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Authorization&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;Bearer maps_live_sk_abc123&lt;br&gt;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;X-Maps-Request-Id&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;req_a1b2c3&lt;br&gt;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;If-None-Match&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;&quot;menu_v42&quot;&lt;br&gt;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Accept-Language&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;de-DE&lt;/code&gt;&lt;/pre&gt;" link="&lt;pre style=&quot;margin-top: 0px; background-color: rgb(248, 248, 248); border-color: rgb(229, 229, 229); border-style: solid; border-width: 0.833333px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;418&quot; class=&quot;code-line language-http&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;color: rgb(0, 0, 255);&quot;&gt;GET&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;/v1/restaurants/rest_abc123/menu&lt;/span&gt; &lt;span class=&quot;hljs-meta&quot; style=&quot;color: rgb(43, 145, 175);&quot;&gt;HTTP/1.1&lt;/span&gt;&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Host&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;api.foodco.com&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Authorization&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;Bearer maps_live_sk_abc123&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;X-Maps-Request-Id&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;req_a1b2c3&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;If-None-Match&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;&quot;menu_v42&quot;&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Accept-Language&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;de-DE&lt;/code&gt;&lt;/pre&gt;" id="Y1QtjGRFmrKap-deU9kp-158">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="184.42" width="442" x="7.070000000000011" y="3382" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;meta charset=&quot;utf-8&quot;&gt;&lt;pre style=&quot;margin-top: 0px; background-color: rgb(248, 248, 248); border-color: rgb(229, 229, 229); border-style: solid; border-width: 0.833333px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;418&quot; class=&quot;code-line language-http&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;&lt;span class=&quot;language-http&quot;&gt;&lt;span class=&quot;hljs-meta&quot; style=&quot;color: rgb(43, 145, 175);&quot;&gt;HTTP/1.1&lt;/span&gt; &lt;span class=&quot;hljs-number&quot; style=&quot;color: rgb(0, 128, 0);&quot;&gt;304&lt;/span&gt; Not Modified&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;ETag&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;&quot;menu_v42&quot;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;" link="&lt;h3 data-line=&quot;353&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;2-view-the-menu-and-customize-items&quot; style=&quot;margin-top: 24px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 1.25em; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;2. View the Menu and Customize Items&lt;/h3&gt;&lt;p data-line=&quot;355&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;strong&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;GET /v1/restaurants/{restaurant_id}/menu&lt;/code&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p data-line=&quot;357&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Returns the full menu for a restaurant, grouped by category. Each item includes available customizations so the user can modify their selection before ordering.&lt;/p&gt;&lt;p data-line=&quot;359&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;strong&gt;Caching:&lt;/strong&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;Menus change infrequently (a few times per day) but get fetched thousands of times per hour for popular restaurants. Partners return&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;ETag&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;and&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;Cache-Control&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;headers to enable conditional requests.&lt;/p&gt;&lt;p data-line=&quot;361&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Response headers:&lt;/p&gt;&lt;table data-line=&quot;363&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;border-collapse: collapse; margin-bottom: 0.7em; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;thead data-line=&quot;363&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;363&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Header&lt;/th&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Example Value&lt;/th&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Purpose&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-line=&quot;365&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;365&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;ETag&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;&quot;menu_v42&quot;&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;Version identifier for the current menu state&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;366&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;Cache-Control&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;max-age=300&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Map.co can serve cached menu for 5 minutes without re-fetching&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;p data-line=&quot;368&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;On subsequent requests, Map.co sends&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;If-None-Match: &quot;menu_v42&quot;&lt;/code&gt;. If the menu hasn&#39;t changed, the partner returns&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;304 Not Modified&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;with no body. If it has changed, the partner returns the full menu with a new ETag.&lt;/p&gt;&lt;p data-line=&quot;370&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;For real-time item availability (e.g. &quot;Lobster tails is sold out&quot;), a 5-minute cache staleness is acceptable because the order endpoint validates freshness at submission time and returns&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;422 item_unavailable&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;for out-of-stock items.&lt;/p&gt;" id="Y1QtjGRFmrKap-deU9kp-159">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="96" width="259" x="539.07" y="3428" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;On subsequent requests, Map.co sends&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 14px; line-height: 1.357em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;If-None-Match: &quot;menu_v42&quot;&lt;/code&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;. If the menu hasn&#39;t changed, the partner returns&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 14px; line-height: 1.357em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;304 Not Modified&lt;/code&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;with no body. If it has changed, the partner returns the full menu with a new ETag.&lt;/span&gt;" link="&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;On subsequent requests, Map.co sends&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 14px; line-height: 1.357em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;If-None-Match: &quot;menu_v42&quot;&lt;/code&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;. If the menu hasn&#39;t changed, the partner returns&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 14px; line-height: 1.357em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;304 Not Modified&lt;/code&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;with no body. If it has changed, the partner returns the full menu with a new ETag.&lt;/span&gt;" id="Y1QtjGRFmrKap-deU9kp-161">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="77" width="550" x="16.997142857143103" y="3322.0014285714296" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;pre style=&quot;margin-top: 0px; background-color: rgb(248, 248, 248); border-color: rgb(229, 229, 229); border-style: solid; border-width: 0.833333px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(59, 59, 59); font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;213&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background: none; padding: 0px; border-radius: 4px; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;GET /v1/restaurants?lat=48.1391&amp;amp;lng=11.5802&amp;amp;radius=3000&lt;br&gt;  -&amp;gt; api.foodco.com&lt;br&gt;  -&amp;gt; api.quickbite.com&lt;br&gt;  -&amp;gt; ...&lt;br&gt;&lt;br&gt;  Maps.co Backend&lt;br&gt;  |&lt;br&gt;  |--- GET /v1/restaurants?lat=48.1391&amp;amp;lng=11.5802&amp;amp;radius=3000 ---&amp;gt; api.foodco.com&lt;br&gt;  |&lt;br&gt;  |--- GET /v1/restaurants?lat=48.1391&amp;amp;lng=11.5802&amp;amp;radius=3000 ---&amp;gt; api.quickbite.com&lt;br&gt;  |&lt;br&gt;  |--- GET /v1/restaurants?lat=48.1391&amp;amp;lng=11.5802&amp;amp;radius=3000 ---&amp;gt; ...&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;" link="&lt;pre style=&quot;margin-top: 0px; background-color: rgb(248, 248, 248); border-color: rgb(229, 229, 229); border-style: solid; border-width: 0.833333px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;213&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;GET /v1/restaurants?lat=48.1391&amp;amp;lng=11.5802&amp;amp;radius=3000&#xa;  -&amp;gt; api.foodco.com&#xa;  -&amp;gt; api.eatsde.com&#xa;  -&amp;gt; api.delivereu.com&#xa;&#xa;  Maps.co Backend&#xa;  |&#xa;  |--- GET /v1/restaurants?lat=48.1391&amp;amp;lng=11.5802&amp;amp;radius=3000 ---&amp;gt; api.foodco.com&#xa;  |&#xa;  |--- GET /v1/restaurants?lat=48.1391&amp;amp;lng=11.5802&amp;amp;radius=3000 ---&amp;gt; api.eatsde.com&#xa;  |&#xa;  |--- GET /v1/restaurants?lat=48.1391&amp;amp;lng=11.5802&amp;amp;radius=3000 ---&amp;gt; api.delivereu.com&lt;/code&gt;&lt;/pre&gt;" id="Y1QtjGRFmrKap-deU9kp-180">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="235" width="544.93" x="10" y="8080" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="Y1QtjGRFmrKap-deU9kp-183" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="161" width="992.84" x="31.999999999999993" y="-382" as="geometry" />
        </mxCell>
        <UserObject label="&lt;p data-line=&quot;65&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;strong&gt;Nodes&lt;/strong&gt;&lt;/p&gt;&lt;ul data-line=&quot;67&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;li data-line=&quot;67&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Map.co App&lt;/strong&gt;&amp;nbsp;-- User interface: restaurants, menus, order form, live tracking.&lt;/li&gt;&lt;li data-line=&quot;68&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Map.co Backend&lt;/strong&gt;&amp;nbsp;-- Orchestrator. Calls partner APIs, stores order state, receives webhooks. Never exposes partner APIs directly to the app (controls caching, error handling, failover).&lt;/li&gt;&lt;li data-line=&quot;69&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Food.co Partner API&lt;/strong&gt;&amp;nbsp;-- Every partner implements the same contract. Map.co talks to all of them identically.&lt;/li&gt;&lt;li data-line=&quot;70&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Webhook Receiver&lt;/strong&gt;&amp;nbsp;-- Listens at&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;POST /v1/webhooks/delivery-events&lt;/code&gt;. Validates HMAC signature, deduplicates on&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;event_id&lt;/code&gt;, writes status to the Order State DB. Ingestion point for all partner-pushed events.&lt;/li&gt;&lt;li data-line=&quot;71&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Order State DB&lt;/strong&gt;&amp;nbsp;-- Map.co&#39;s source of truth for order status. Every change (webhook or polling fallback) lands here.&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;status_history&lt;/code&gt;&amp;nbsp;timestamps power per-partner SLA enforcement (e.g., detecting courier no-shows).&lt;/li&gt;&lt;/ul&gt;&lt;p data-line=&quot;73&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;strong&gt;Edges&lt;/strong&gt;&lt;/p&gt;&lt;p data-line=&quot;75&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;Edges 1--4 are synchronous (user-initiated request-response). Edge 5 is asynchronous (partner-pushed).&lt;/p&gt;&lt;ol data-line=&quot;77&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;li data-line=&quot;77&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;App -&amp;gt; Backend&lt;/strong&gt;&amp;nbsp;-- User action (open map, tap restaurant, confirm order) sent to backend.&lt;/li&gt;&lt;li data-line=&quot;78&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Backend -&amp;gt; App&lt;/strong&gt;&amp;nbsp;-- Response rendered in UI (restaurant list, menu, order confirmation, tracking status).&lt;/li&gt;&lt;li data-line=&quot;79&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Backend -&amp;gt; Partner API&lt;/strong&gt;&amp;nbsp;-- The core boundary. Map.co calls the partner over HTTP using the reverse API contract. This is the design surface of the entire system.&lt;/li&gt;&lt;li data-line=&quot;80&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Partner API -&amp;gt; Backend&lt;/strong&gt;&amp;nbsp;-- JSON response (restaurant data, order confirmation, status).&lt;/li&gt;&lt;li data-line=&quot;81&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;strong&gt;Partner -&amp;gt; Webhook Receiver&lt;/strong&gt;&amp;nbsp;-- Async push when state changes on the partner side (courier assigned, food ready, delivered).&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;font color=&quot;#202020&quot; face=&quot;-apple-system, system-ui, Segoe WPC, Segoe UI, system-ui, Ubuntu, Droid Sans, sans-serif&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; float: none; display: inline !important;&quot;&gt;Edges 1–4 are synchronous: the user does something, and the systems exchange requests and responses in real time.&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(59, 59, 59), rgb(186, 186, 186)); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; background-color: transparent;&quot;&gt;Edges 5 and 7 are asynchronous: the partner pushes updates to Map.co when something changes on their side, without the user asking.&lt;/span&gt;&lt;/div&gt;" id="Y1QtjGRFmrKap-deU9kp-184">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="488" width="926.84" x="30" y="-221" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="Y1QtjGRFmrKap-deU9kp-188" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;margin-top: 0px; background-color: rgb(248, 248, 248); border-color: rgb(229, 229, 229); border-style: solid; border-width: 0.833333px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;1096&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;confirmed → preparing → ready_for_pickup → picked_up → en_route → delivered&#xa;     │           │                                          │&#xa;     └───────────┴──────────────────────────────────────────┴──→ cancelled&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="113" width="847.39" x="4.29999999999994" y="5410" as="geometry" />
        </mxCell>
        <UserObject label="&lt;h2 data-line=&quot;628&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;partner-onboarding-and-developer-experience&quot; style=&quot;margin-top: 24px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 1.5em; padding-bottom: 0.3em; border-bottom: 1px solid rgba(0, 0, 0, 0.18); border-top-color: rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18); position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Partner Onboarding and Developer Experience&lt;/h2&gt;&lt;h3 data-line=&quot;630&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;credential-provisioning&quot; style=&quot;margin-top: 24px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 1.25em; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Credential Provisioning&lt;/h3&gt;&lt;p data-line=&quot;632&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;strong&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); background-color: rgb(236, 236, 236); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;POST https://api.mapco.com/partners/register&lt;/code&gt;&lt;/strong&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;(Map.co endpoint)&lt;/p&gt;&lt;p data-line=&quot;634&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Response:&lt;/p&gt;&lt;pre style=&quot;margin-top: 0px; background-color: rgb(234, 234, 234); border-color: rgb(238, 238, 241); border-style: solid; border-width: 1px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(32, 32, 32); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;636&quot; class=&quot;code-line language-json&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(32, 32, 32); background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;{&lt;/span&gt;&lt;br&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;partner_id&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;partner_foodco&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;api_key&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;mk_live_...&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;webhook_secret&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;whsec_...&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;webhook_url&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;https://api.mapco.com/webhooks/partner/order-status&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;sandbox_url&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;https://sandbox.mapco.com&quot;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;}&lt;/span&gt;&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;ul data-line=&quot;646&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;li data-line=&quot;646&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); background-color: rgb(236, 236, 236); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;api_key&lt;/code&gt;: Map.co sends as&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); background-color: rgb(236, 236, 236); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;Authorization: Bearer&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;when calling Food.co&#39;s endpoints.&lt;/li&gt;&lt;li data-line=&quot;647&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); background-color: rgb(236, 236, 236); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;webhook_secret&lt;/code&gt;: shared secret for HMAC signatures on webhooks.&lt;/li&gt;&lt;li data-line=&quot;648&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); background-color: rgb(236, 236, 236); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;webhook_url&lt;/code&gt;: where Food.co sends status updates.&lt;/li&gt;&lt;li data-line=&quot;649&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); background-color: rgb(236, 236, 236); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;sandbox_url&lt;/code&gt;: test environment for integration development.&lt;/li&gt;&lt;/ul&gt;&lt;p data-line=&quot;651&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;The&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); background-color: rgb(236, 236, 236); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;api_key&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;/&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); background-color: rgb(236, 236, 236); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;webhook_secret&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;pair maps directly to Stripe&#39;s publishable key / webhook signing secret pair.&lt;/p&gt;&lt;p data-line=&quot;651&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(32, 32, 32), rgb(210, 210, 210)); font-size: 1.25em; background-color: transparent;&quot;&gt;Developer Experience&lt;/span&gt;&lt;/p&gt;&lt;p data-line=&quot;655&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;Map.co provides three things to reduce integration friction:&lt;/p&gt;&lt;ol data-line=&quot;657&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;li data-line=&quot;657&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;p data-line=&quot;657&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative;&quot;&gt;&lt;strong&gt;Sandbox environment.&lt;/strong&gt;&amp;nbsp;A test environment where partners develop against mock data without real orders, real users, or real money. The sandbox simulates the full order lifecycle: Map.co sends test requests, the partner returns responses, webhooks flow back, and both sides validate the integration end-to-end. Same model as Stripe&#39;s test mode.&lt;/p&gt;&lt;/li&gt;&lt;li data-line=&quot;659&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;p data-line=&quot;659&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative;&quot;&gt;&lt;strong&gt;Reference implementation.&lt;/strong&gt;&amp;nbsp;A sample server (Python and Node) that passes all contract tests. Partners use it as a starting point or as a reference to verify their own implementation.&lt;/p&gt;&lt;/li&gt;&lt;li data-line=&quot;661&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;p data-line=&quot;661&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative;&quot;&gt;&lt;strong&gt;Contract test suite.&lt;/strong&gt;&amp;nbsp;An automated test suite partners run against their own API before going live. It exercises every endpoint, validates response schemas, tests error cases, and verifies webhook delivery. Map.co gates production access on passing the test suite.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;font color=&quot;#202020&quot; face=&quot;-apple-system, system-ui, Segoe WPC, Segoe UI, system-ui, Ubuntu, Droid Sans, sans-serif&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;h2 data-line=&quot;592&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;webhooks--foodco-calls-mapco&quot; style=&quot;margin-top: 24px; margin-bottom: 16px; line-height: 1.25; padding-bottom: 0.3em; border-bottom: 1px solid rgba(0, 0, 0, 0.18); border-top-color: rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18); position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif;&quot;&gt;Webhooks — Food.co Calls Map.co&lt;/h2&gt;&lt;p data-line=&quot;594&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;Polling&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;GET /orders/{id}&lt;/code&gt;&amp;nbsp;every few seconds doesn&#39;t scale across millions of orders for state transitions. Instead, Food.co pushes status updates to Map.co.&lt;/p&gt;&lt;p data-line=&quot;596&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;strong&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;POST https://api.mapco.com/webhooks/partner/order-status&lt;/code&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p data-line=&quot;598&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;Request headers:&lt;/p&gt;&lt;table data-line=&quot;600&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;border-collapse: collapse; margin-bottom: 0.7em; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;thead data-line=&quot;600&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;600&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Header&lt;/th&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Value&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-line=&quot;602&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;602&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;X-Webhook-Signature&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;HMAC-SHA256 of the raw body using a shared secret&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;603&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;X-Webhook-Timestamp&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Unix timestamp when the event was created&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;p data-line=&quot;605&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;Request body:&lt;/p&gt;&lt;pre style=&quot;margin-top: 0px; background-color: rgb(234, 234, 234); border-color: rgb(238, 238, 241); border-style: solid; border-width: 1px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; text-wrap-mode: wrap; color: rgb(32, 32, 32); font-size: 14px;&quot;&gt;&lt;code data-line=&quot;607&quot; class=&quot;code-line language-json&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;{&lt;/span&gt;&lt;br/&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;event_type&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;order.status_updated&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br/&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;order_id&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;ord_food_456&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br/&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;status&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;picked_up&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br/&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;timestamp&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;2026-03-23T12:58:00Z&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br/&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;courier&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-punctuation&quot;&gt;{&lt;/span&gt;&lt;br/&gt;    &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;name&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;Lisa&quot;&lt;/span&gt;&lt;br/&gt;  &lt;span class=&quot;hljs-punctuation&quot;&gt;}&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&lt;br/&gt;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;estimated_arrival_at&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;2026-03-23T13:10:00Z&quot;&lt;/span&gt;&lt;br/&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;}&lt;/span&gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p data-line=&quot;620&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;strong&gt;Signature verification:&lt;/strong&gt;&amp;nbsp;Map.co computes&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;HMAC-SHA256(webhook_secret, timestamp + &quot;.&quot; + raw_body)&lt;/code&gt;&amp;nbsp;and compares it to the header. Rejects if the timestamp is older than 5 minutes (replay protection). Same algorithm as Stripe&#39;s&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;Stripe-Signature&lt;/code&gt;&amp;nbsp;with&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;v1=&lt;/code&gt;&amp;nbsp;signatures.&lt;/p&gt;&lt;p data-line=&quot;622&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;strong&gt;Retry policy:&lt;/strong&gt;&amp;nbsp;If Map.co returns non-2xx, Food.co retries with exponential backoff: 1s, 5s, 30s, 5min, 1hr. After 24 hours of failures, the event is dropped and Map.co falls back to polling.&lt;/p&gt;&lt;p data-line=&quot;624&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;strong&gt;Idempotency:&lt;/strong&gt;&amp;nbsp;Map.co handles duplicate webhook deliveries using&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;order_id&lt;/code&gt;&amp;nbsp;+&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;status&lt;/code&gt;&amp;nbsp;+&amp;nbsp;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(96, 96, 96); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;timestamp&lt;/code&gt;&amp;nbsp;as a dedup key. Processing the same event twice is a no-op.&lt;/p&gt;&lt;/div&gt;" id="Y1QtjGRFmrKap-deU9kp-190">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="812" width="788.71" x="32" y="8308" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;p data-line=&quot;631&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Request:&lt;/p&gt;&lt;pre style=&quot;margin-top: 0px; background-color: rgb(248, 248, 248); border-color: rgb(229, 229, 229); border-style: solid; border-width: 0.833333px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;633&quot; class=&quot;code-line language-http&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;color: rgb(0, 0, 255);&quot;&gt;POST&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;/v1/orders/ord_food_456/cancel&lt;/span&gt; &lt;span class=&quot;hljs-meta&quot; style=&quot;color: rgb(43, 145, 175);&quot;&gt;HTTP/1.1&lt;/span&gt;&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Host&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;api.foodco.com&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Authorization&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;Bearer maps_live_sk_abc123&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Content-Type&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;application/json&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;X-Maps-Request-Id&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;req_s9t0u1&#xa;&#xa;&lt;span class=&quot;language-json&quot;&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;{&lt;/span&gt;&#xa;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;maps_order_ref&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;maps_ord_789&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&#xa;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;reason&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;customer_requested&quot;&lt;/span&gt;&#xa;&lt;span class=&quot;hljs-punctuation&quot;&gt;}&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;" link="&lt;p data-line=&quot;631&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Request:&lt;/p&gt;&lt;pre style=&quot;margin-top: 0px; background-color: rgb(248, 248, 248); border-color: rgb(229, 229, 229); border-style: solid; border-width: 0.833333px; border-image: none 100% / 1 / 0 stretch; padding: 16px; border-radius: 3px; overflow: auto; white-space: pre-wrap; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code data-line=&quot;633&quot; class=&quot;code-line language-http&quot; dir=&quot;auto&quot; style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background: none; padding: 0px; border-radius: 4px; font-size: 1em; line-height: 1.357em; display: inline-block; tab-size: 4; position: relative;&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;color: rgb(0, 0, 255);&quot;&gt;POST&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;/v1/orders/ord_food_456/cancel&lt;/span&gt; &lt;span class=&quot;hljs-meta&quot; style=&quot;color: rgb(43, 145, 175);&quot;&gt;HTTP/1.1&lt;/span&gt;&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Host&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;api.foodco.com&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Authorization&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;Bearer maps_live_sk_abc123&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;Content-Type&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;application/json&#xa;&lt;span class=&quot;hljs-attribute&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;X-Maps-Request-Id&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;: &lt;/span&gt;req_s9t0u1&#xa;&#xa;&lt;span class=&quot;language-json&quot;&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;{&lt;/span&gt;&#xa;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;maps_order_ref&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;maps_ord_789&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;&#xa;  &lt;span class=&quot;hljs-attr&quot; style=&quot;color: rgb(255, 0, 0);&quot;&gt;&quot;reason&quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt; &lt;span class=&quot;hljs-string&quot; style=&quot;color: rgb(163, 21, 21);&quot;&gt;&quot;customer_requested&quot;&lt;/span&gt;&#xa;&lt;span class=&quot;hljs-punctuation&quot;&gt;}&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;" id="Y1QtjGRFmrKap-deU9kp-191">
