        <UserObject label="&lt;h1 data-line=&quot;625&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;mapco-food-ordering--reverse-api-design&quot; style=&quot;margin-top: 0px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 2em; padding-bottom: 0.3em; border-bottom: 1px solid rgba(0, 0, 0, 0.18); border-top-color: rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18); position: relative; color: rgb(59, 59, 59); font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;Map.co Food Ordering — Reverse API Design&lt;/font&gt;&lt;/h1&gt;&lt;h2 data-line=&quot;627&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;context&quot; style=&quot;margin-top: 24px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 1.5em; padding-bottom: 0.3em; border-bottom: 1px solid rgba(0, 0, 0, 0.18); border-top-color: rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18); position: relative; color: rgb(59, 59, 59); font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;Context&lt;/font&gt;&lt;/h2&gt;&lt;p data-line=&quot;629&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;Map.co (think Google Maps) has signed partnerships with the largest on-demand food delivery companies worldwide — the most prominent being Food.co (think Uber Eats, DoorDash). The goal: let Map.co users order food from nearby restaurants directly inside the Maps app, without switching to another app.&lt;/font&gt;&lt;/p&gt;&lt;p data-line=&quot;631&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;strong style=&quot;color: light-dark(rgb(59, 59, 59), rgb(186, 186, 186)); background-color: transparent;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;User flow:&lt;/font&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ol data-line=&quot;634&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;li data-line=&quot;634&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;Select a restaurant&lt;/font&gt;&lt;/li&gt;&lt;li data-line=&quot;635&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;View the menu and select/customize items&lt;/font&gt;&lt;/li&gt;&lt;li data-line=&quot;636&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;Make the order&lt;/font&gt;&lt;/li&gt;&lt;li data-line=&quot;637&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;Track the order&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p data-line=&quot;639&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;strong&gt;&lt;font face=&quot;Verdana&quot;&gt;Design objectives:&lt;/font&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ol data-line=&quot;640&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative; color: rgb(59, 59, 59); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;li data-line=&quot;640&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;High-level architecture between Map.co and Food.co partners&lt;/font&gt;&lt;/li&gt;&lt;li data-line=&quot;641&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;API endpoints each Food.co partner must implement, with key request/response fields&lt;/font&gt;&lt;/li&gt;&lt;li data-line=&quot;642&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;Additional functionality Map.co needs to expose to each partner (webhooks, partner onboarding + dev experience)&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;" link="&lt;h1 data-line=&quot;625&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;mapco-food-ordering--reverse-api-design&quot; style=&quot;margin-top: 0px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 2em; padding-bottom: 0.3em; border-bottom: 1px solid rgba(0, 0, 0, 0.18); border-top-color: rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18); position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Map.co Food Ordering — Reverse API Design&lt;/h1&gt;&lt;h2 data-line=&quot;627&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;context&quot; style=&quot;margin-top: 24px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 1.5em; padding-bottom: 0.3em; border-bottom: 1px solid rgba(0, 0, 0, 0.18); border-top-color: rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18); position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Context&lt;/h2&gt;&lt;p data-line=&quot;629&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Map.co (think Google Maps) has signed partnerships with the largest on-demand food delivery companies worldwide — the most prominent being Food.co (think Uber Eats, DoorDash). The goal: let Map.co users order food from nearby restaurants directly inside the Maps app, without switching to another app.&lt;/p&gt;&lt;p data-line=&quot;631&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;The frontend team has built a working UX. The delivery partners have agreed to integrate against a &quot;reverse API&quot; — an interface of Map.co&#39;s design where Map.co makes the requests and partners handle them.&lt;/p&gt;&lt;p data-line=&quot;633&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;strong&gt;User flow:&lt;/strong&gt;&lt;/p&gt;&lt;ol data-line=&quot;634&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;li data-line=&quot;634&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;Select a restaurant&lt;/li&gt;&lt;li data-line=&quot;635&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;View the menu and select/customize items&lt;/li&gt;&lt;li data-line=&quot;636&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;Make the order&lt;/li&gt;&lt;li data-line=&quot;637&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;Track the order&lt;/li&gt;&lt;/ol&gt;&lt;p data-line=&quot;639&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;strong&gt;Design objectives:&lt;/strong&gt;&lt;/p&gt;&lt;ol data-line=&quot;640&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 0.7em; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;li data-line=&quot;640&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;High-level architecture between Map.co and Food.co partners&lt;/li&gt;&lt;li data-line=&quot;641&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;API endpoints each Food.co partner must implement, with key request/response fields&lt;/li&gt;&lt;li data-line=&quot;642&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;Additional functionality Map.co needs to expose to each partner&lt;/li&gt;&lt;/ol&gt;" id="3og-4Hi9DXqhYG57hDMo-100">
