r codes:&lt;/p&gt;&lt;table data-line=&quot;41&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;border-collapse: collapse; margin-bottom: 0.7em; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;thead data-line=&quot;41&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;41&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Status&lt;/th&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Code&lt;/th&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;When&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-line=&quot;43&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;43&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;400&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;invalid_request&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;Missing/malformed required params (lat, lng)&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;44&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;429&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;rate_limited&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Too many requests&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;45&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0