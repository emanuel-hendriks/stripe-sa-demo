tom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Header&lt;/th&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Purpose&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-line=&quot;155&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;155&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;If-None-Match&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;ETag from previous response. Partner returns&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;304&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;if unchanged&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;156&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;Accept-Language&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Preferred language for menu content&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;p data-line=&quot;289&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Error codes:&lt;/p&gt;&lt;table data-line=&quot;160&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;border-collapse: collapse; margin-bottom: 0.7em; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;thead data-line=&quot;160&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;160&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Status&lt;/th&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;Code&lt;/th&gt;&lt;th style=&quot;text-align: left; border-bottom: 1px solid rgba(0, 0, 0, 0.69); padding: 5px 10px; border-top-color: rgba(0, 0, 0, 0.69); border-right-color: rgba(0, 0, 0, 0.69); border-left-color: rgba(0, 0, 0, 0.69);&quot;&gt;When&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-line=&quot;162&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;tr data-line=&quot;162&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;400&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;invalid_request&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-color: rgba(0, 0, 0, 0.18);&quot;&gt;Missing/malformed restaurant ID&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;163&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;404&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;restaurant_not_found&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Restaurant does not exist&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;164&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;429&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;rate_limited&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Too many requests&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;165&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;503&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;service_unavailable&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Partner temporarily down&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" id="Y1QtjGRFmrKap-deU9kp-111">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="573" width="655.24" x="12.759999999999998" y="2208" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;p data-line=&quot;77&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;b&gt;Sync (Obj 1–3): &lt;br&gt;&lt;/b&gt;&lt;br&gt;App -&amp;gt; Backend -&amp;gt; Partner API -&amp;gt; Backend -&amp;gt; DB. &lt;br&gt;&lt;br&gt;Backend orchestrates all partner calls, owns caching (ETag/304), circuit-breaking, and price validation. Partners never touch payments.&lt;/p&gt;&lt;p data-line=&quot;81&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;&lt;b&gt;Async (Obj 4): &lt;br&gt;&lt;/b&gt;&lt;br&gt;Partner -&amp;gt; Webhook Receiver (HMAC-verified, deduplicated by event_id) -&amp;gt; DB -&amp;gt; App via WebSocket/SSE. Direction inverts -- partners push, Map.co listens. Fallback: Backend polls GET /v1/orders/{id} when no webhook arrives.&lt;/p&gt;&lt;p data-line=&quot;85&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(32, 32, 32); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px;&quot;&gt;Backend mediates every partner interaction. DB is the single source of truth, written by both paths&lt;/p&gt;" link="&lt;meta charset=&quot;utf-8&quot;&gt;&lt;p&gt;Reverse API architecture. Map.co defines the contract; N delivery partners implement it. Same endpoint paths, different base URLs.&lt;/p&gt;&#xa;&lt;p&gt;&lt;strong&gt;Sync path (Obj 1–3):&lt;/strong&gt; App → Backend → Partner API → Backend → DB. The Backend orchestrates all partner calls over HTTPS, owns caching (ETag/304), circuit-breaking, and server-side price validation against the partner&#39;s authoritative total. Partners never touch payments — Map.co collects from the user and batch-settles.&lt;/p&gt;&#xa;&lt;p&gt;&lt;strong&gt;Async path (Obj 4, primary):&lt;/strong&gt; Partner → Webhook Receiver (HMAC-SHA256 verified, deduplicated by event_id) → DB → App (WebSocket/SSE). Communication direction inverts — partners push status changes, Map.co listens.&lt;/p&gt;&#xa;&lt;p&gt;&lt;strong&gt;Fallback path (Obj 4):&lt;/strong&gt; Backend polls &lt;code&gt;GET /v1/orders/{id}&lt;/code&gt; when no webhook arrives within the expected window.&lt;/p&gt;&#xa;&lt;p&gt;The Backend mediates every partner interaction, so Map.co controls the UX regardless of individual partner reliability. The DB is the single source of truth — written to by both the sync path (on order creation) and the async path (on status updates).&lt;/p&gt;" id="Y1QtjGRFmrKap-deU9kp-116">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="198" width="1626.92" x="47" y="-605" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;h3 data-line=&quot;459&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;4-track-the-order&quot; style=&quot;margin-top: 24px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 1.25em; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;4. Track the Order&lt;/h3&gt;&lt;p data-line=&quot;461&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Two mechanisms: webhooks (primary) and polling (fallback).&lt;/p&gt;&lt;h4 data-line=&quot;463&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; id=&quot;4a-webhook----partner-pushes-to-mapsco&quot; style=&quot;margin-top: 24px; font-weight: 600; margin-bottom: 16px; line-height: 1.25; font-size: 14px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;4a. Webhook -- Partner pushes to Maps.co&lt;/h4&gt;&lt;p data-line=&quot;465&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;strong&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;POST /v1/webhooks/delivery-events&lt;/code&gt;&lt;/strong&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;(Maps.co exposes this)&lt;/p&gt;&lt;p data-line=&quot;467&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;margin-top: 0px; margin-bottom: 16px; position: relative; color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe WPC&amp;quot;, &amp;quot;