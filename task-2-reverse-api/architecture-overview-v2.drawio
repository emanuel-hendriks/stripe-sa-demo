quot;&gt;409&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;cancellation_not_allowed&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Order is&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;picked_up&lt;/code&gt;,&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;en_route&lt;/code&gt;, or&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;delivered&lt;/code&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;620&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;429&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;rate_limited&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Too many requests&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" id="Y1QtjGRFmrKap-deU9kp-195">
