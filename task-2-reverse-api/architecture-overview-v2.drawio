left-color: rgba(0, 0, 0, 0.18);&quot;&gt;string&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;no&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Filter: &quot;italian&quot;, &quot;sushi&quot;, etc.&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;36&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&quot;&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;&lt;code style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(59, 59, 59); background-color: rgba(0, 0, 0, 0.12); padding: 1px 3px; border-radius: 4px; font-size: 1em; line-height: 1.357em;&quot;&gt;limit&lt;/code&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;int&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;no&lt;/td&gt;&lt;td style=&quot;padding: 5px 10px; border-top: 1px solid rgba(0, 0, 0, 0.18); border-right-color: rgba(0, 0, 0, 0.18); border-bottom-color: rgba(0, 0, 0, 0.18); border-left-color: rgba(0, 0, 0, 0.18);&quot;&gt;Page size. Default: 20&lt;/td&gt;&lt;/tr&gt;&lt;tr data-line=&quot;37&quot; class=&quot;code-line&quot; dir=&quot;auto&quot; style=&quot;position: relative;&